# -----------------------------------------------------------------------------
# SmartCloudOPS - Configuración de Entorno (Dokploy)
# -----------------------------------------------------------------------------

# 1. Base de Datos (PostgreSQL)
# En Dokploy -> Databases -> Tu DB -> "Internal Connection String"
# IMPORTANTE: Usa la URL INTERNA para que el tráfico no salga a internet (más rápido y seguro).
DATABASE_URL="postgresql://postgres:password@postgresql:5432/smartcloudops?schema=public"

# 2. Autenticación (NextAuth v4)
# La URL pública de tu aplicación.
NEXTAUTH_URL="https://cloud.otisperu.com"

# Un secreto para firmar las cookies de sesión. NO lo compartas.
# Puedes generar uno nuevo con: openssl rand -base64 32
NEXTAUTH_SECRET="K7yG9pT3sWz8qX5vM2rD4eF1c8nH0jB6L5vC3zQ9xP4="

# 3. Google OAuth (mailer-otis)
# Obtenidos en console.cloud.google.com
GOOGLE_CLIENT_ID="16783778877-64c7gsk2g7fplo3gv69ele9q60vcpejj.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="TU_GOOGLE_CLIENT_SECRET_AQUI"

# 4. Entorno de Ejecución (Opcional en Dokploy)
NODE_ENV="production"
