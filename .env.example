# SmartCloudOPS — Variables de Entorno

# ─── Base de Datos (PostgreSQL) ───────────────────────────────────────────────
# Para desarrollo local con Docker:
DATABASE_URL="postgresql://smartcloud:smartcloud@localhost:5432/smartcloudops?schema=public"
# En Dokploy, reemplazar con credenciales del servicio postgres interno

# ─── Autenticación (NextAuth.js) ──────────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_WITH_OPENSSL"
NEXTAUTH_URL="http://localhost:3000"
# En producción (Dokploy): NEXTAUTH_URL="https://app.tudominio.com"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Crear en: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Infraestructura (Contabo API) ────────────────────────────────────────────
# Generar en: https://my.contabo.com/api/details
CONTABO_CLIENT_ID=""
CONTABO_CLIENT_SECRET=""
CONTABO_USERNAME=""
CONTABO_PASSWORD=""
CONTABO_API_URL="https://api.contabo.com"

# ─── Pagos (Stripe) ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── Almacenamiento (Backups) ─────────────────────────────────────────────────
# AWS S3 o Backblaze B2
BACKUP_S3_BUCKET=""
BACKUP_S3_REGION=""
BACKUP_S3_ACCESS_KEY=""
BACKUP_S3_SECRET_KEY=""
BACKUP_S3_ENDPOINT="" # Para Backblaze: s3.us-west-004.backblazeb2.com

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
